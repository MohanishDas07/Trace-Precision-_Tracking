generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  baselineCo2e Float    @default(0)
  currentCo2e  Float    @default(0)
  createdAt    DateTime @default(now())

  footprintLogs FootprintLog[]
  userActions   UserAction[]
}

model FootprintLog {
  id         String   @id @default(uuid())
  userId     String
  category   String
  scoreCo2e  Float
  sourceData String
  loggedAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Action {
  id                String     @id @default(uuid())
  title             String
  description       String
  category          String
  impactCo2eEstimate Float
  difficulty        String

  userActions UserAction[]
}

model UserAction {
  id              String       @id @default(uuid())
  userId          String
  actionId        String
  status          String       @default("ACTIVE")
  startedAt       DateTime     @default(now())
  completedAt     DateTime?
  actualSavingsCo2e Float      @default(0)

  user   User   @relation(fields: [userId], references: [id])
  action Action @relation(fields: [actionId], references: [id])

  @@unique([userId, actionId])
}
